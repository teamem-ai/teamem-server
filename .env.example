# teamem portal — deployment environment (copy to .env and fill in)

# ── Required ─────────────────────────────────────────────────────────────
# No default on purpose: compose refuses to start without it.
POSTGRES_PASSWORD=

# ── Optional (defaults shown) ────────────────────────────────────────────
POSTGRES_USER=teamem
POSTGRES_DB=teamem

# Host port the portal is published on (container listens on 8080).
TEAMEM_PORT=8080

# Single-process mode: server embeds the compile worker.
# When true, bring up only postgres+server:
#   TEAMEM_ALL_IN_ONE=true docker compose up -d postgres server
TEAMEM_ALL_IN_ONE=false

# ── GitHub App / webhook ────────────────────────────────────────────────
# Webhook secret used to verify incoming GitHub events.
TEAMEM_GITHUB_WEBHOOK_SECRET=
# GitHub App numeric ID (from the app's settings page).
TEAMEM_GITHUB_APP_ID=
# Installation ID for the target org/user (from the app's install page).
TEAMEM_GITHUB_INSTALLATION_ID=
# RSA private key (PEM) for signing GitHub App JWTs.
# Use the key downloaded when the App was created.
TEAMEM_GITHUB_PRIVATE_KEY=

# ── LLM provider keys (BYO — bring your own key) ─────────────────────────
# M0 reads these from env; M2 moves provider config into the portal UI.
# TEAMEM_-prefixed on purpose so the ambient ANTHROPIC_API_KEY /
# OPENAI_API_KEY of the host shell are never inherited by accident.
# Configure at least one provider for compilation to run.
TEAMEM_ANTHROPIC_API_KEY=
TEAMEM_OPENAI_API_KEY=
TEAMEM_OPENROUTER_API_KEY=

# Any OpenAI-compatible endpoint (DeepSeek, LM Studio, internal gateway) —
# for teams that need LLM calls to stay inside their network.
TEAMEM_OPENAI_COMPAT_BASE_URL=
TEAMEM_OPENAI_COMPAT_API_KEY=
