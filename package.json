{
  "name": "teamem-server",
  "version": "0.0.0",
  "private": true,
  "description": "teamem portal (server monorepo) — self-hostable team knowledge compiler for AI coding agents",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter @teamem/server dev",
    "build": "pnpm --filter @teamem/server build",
    "start": "pnpm --filter @teamem/server start",
    "worker": "pnpm --filter @teamem/server worker",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run --passWithNoTests",
    "db:generate": "pnpm --filter @teamem/server db:generate",
    "db:migrate": "pnpm --filter @teamem/server db:migrate",
    "bootstrap": "pnpm --filter @teamem/server bootstrap",
    "test:integration": "pnpm --filter @teamem/server test:integration",
    "test:e2e": "pnpm --filter @teamem/server test:e2e",
    "test:compose": "pnpm --filter @teamem/server test:compose",
    "m0:f1-reliability": "pnpm --filter @teamem/server m0:f1-reliability"
  },
  "devDependencies": {
    "eslint": "^9.31.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  }
}
